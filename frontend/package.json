{
  "name": "vite_react_template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint eslint.config.js src",
    "lint:fix": "eslint eslint.config.js src --fix",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "validate": "yarn lint && yarn format && yarn typecheck",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test -c ./playwright.configuration.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@floating-ui/react": "^0.27.19",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "swr": "^2.4.1",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-config": "github:eetu/eslint-config#v2.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.11",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "yarn@4.12.0"
}
